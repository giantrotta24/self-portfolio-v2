---
const links = [
  { href: '/services/', label: 'Services' },
  { href: '/case-studies/', label: 'Case studies' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
const current = Astro.url.pathname;
---

<header class="relative z-20 border-b border-line">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-4 px-6 py-5">
    <a href="/" class="font-display text-lg font-bold tracking-tight">
      Gian Trotta<span class="text-flare">.</span>
    </a>

    <input
      type="checkbox"
      id="nav-toggle"
      class="peer sr-only"
      aria-controls="site-nav"
    />

    <label
      for="nav-toggle"
      class="nav-toggle-btn -mr-2 cursor-pointer p-2 md:hidden"
    >
      <span class="sr-only">Menu</span>
      <span class="nav-icon relative block h-6 w-6" aria-hidden="true">
        <span class="nav-icon-bar absolute left-1 top-[5px] h-0.5 w-4 rounded-full bg-current"></span>
        <span class="nav-icon-bar absolute left-1 top-[11px] h-0.5 w-4 rounded-full bg-current"></span>
        <span class="nav-icon-bar absolute left-1 top-[17px] h-0.5 w-4 rounded-full bg-current"></span>
      </span>
    </label>

    <!-- Full-viewport dismiss target: clicking unchecks #nav-toggle via the label -->
    <label
      for="nav-toggle"
      class="nav-dismiss fixed inset-0 z-10 hidden cursor-default max-md:peer-checked:block"
      aria-hidden="true"
    ></label>

    <nav
      id="site-nav"
      class="absolute inset-x-0 top-full z-20 hidden border-b border-line bg-porcelain px-6 pb-6 shadow-lg max-md:peer-checked:block md:static md:z-auto md:block md:border-0 md:bg-transparent md:p-0 md:shadow-none"
      aria-label="Main"
    >
      <ul
        class="flex flex-col gap-1 pt-2 md:flex-row md:flex-wrap md:items-center md:gap-x-6 md:gap-y-2 md:pt-0 md:text-sm"
      >
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={current.startsWith(href) ? 'page' : undefined}
                class="block py-2 text-mist hover:text-ink aria-[current=page]:font-semibold aria-[current=page]:text-ink md:py-0"
              >
                {label}
              </a>
            </li>
          ))
        }
        <li class="mt-3 md:mt-0">
          <a
            href="/contact/"
            class="inline-block bg-ink px-4 py-2 font-semibold text-porcelain hover:bg-steel"
          >
            Book a checkup
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav-icon-bar {
    transform-origin: center;
    transition:
      transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 200ms ease;
  }

  #nav-toggle:checked + .nav-toggle-btn .nav-icon-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  #nav-toggle:checked + .nav-toggle-btn .nav-icon-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  #nav-toggle:checked + .nav-toggle-btn .nav-icon-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-icon-bar {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLInputElement | null;

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.checked) {
      toggle.checked = false;
      toggle.focus();
    }
  });
</script>
