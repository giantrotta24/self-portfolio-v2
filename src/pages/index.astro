---
import Base from '../layouts/Base.astro';
import AvailabilityBadge from '../components/AvailabilityBadge.astro';

const doors = [
  {
    name: 'New Website Build',
    blurb: 'Starting from zero? Same result, built right the first time.',
    meta: 'Fixed price',
  },
  {
    name: 'Site Checkup',
    blurb:
      'A fixed-price audit of your speed, Google visibility, and AI visibility — with a plain-English report.',
    meta: 'Fixed price',
  },
  {
    name: 'Care Plan',
    blurb: 'Monthly updates, monitoring, and small changes, so your site never rots again.',
    meta: 'Monthly retainer',
  },
];
---

<Base
  title="Gian Trotta — Fast websites for Northeast Ohio small businesses"
  description="Your website should be bringing you customers, not costing you a subscription. Website rescues, rebuilds, and checkups by a senior engineer in Cleveland, Ohio."
>
  <!-- Hero: headline vs. the receipt that proves it -->
  <section class="mx-auto max-w-6xl px-6 pb-20 pt-16 lg:pt-20">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p
          class="flex flex-wrap items-center gap-x-2 gap-y-1 font-utility text-sm uppercase tracking-widest text-flare"
        >
          <span class="w-full sm:w-auto">Cleveland, Ohio</span>
          <span aria-hidden="true" class="hidden sm:inline">·</span>
          <AvailabilityBadge />
        </p>
        <h1
          class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl xl:text-6xl"
        >
          Your website should bring in customers, not another monthly bill.
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-mist">
          By day, I keep a massive site fast for millions. Locally, I handle Wix and Squarespace
          rescues, new sites, and tune-ups.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="rounded-md bg-flare-deep px-6 py-3 font-semibold text-porcelain hover:bg-flare"
          >
            Book a free 15-minute call
          </a>
          <a
            href="/services/"
            class="rounded-md border border-ink px-6 py-3 font-semibold hover:bg-ink hover:text-porcelain"
          >
            See services
          </a>
        </div>
      </div>

      <!-- Signature: the checkup receipt — this site's own diagnostic slip -->
      <aside
        class="receipt-wrap transition-transform duration-300 lg:col-span-5 lg:-rotate-2 lg:hover:rotate-0 motion-reduce:transition-none"
        aria-label="This site's own checkup results"
      >
        <div class="receipt-paper px-7 py-9 font-utility">
          <p class="text-xs uppercase tracking-widest text-mist">
            Site checkup · giantrotta.dev
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4 border-b border-dotted border-line pb-3">
              <dt>Google speed score</dt>
              <dd class="font-bold text-steel">100 / 100</dd>
            </div>
            <div class="flex justify-between gap-4 border-b border-dotted border-line pb-3">
              <dt>Loads in</dt>
              <dd class="font-bold text-steel">under 1 second</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt>Monthly platform fee</dt>
              <dd class="font-bold text-flare">$0</dd>
            </div>
          </dl>
          <p class="mt-6 border-t border-dashed border-line pt-4 text-xs leading-relaxed text-mist">
            This site is built the way I build yours. The previous version took 72 seconds to load
            on a phone.
            <a href="/blog/" class="underline hover:text-ink">That story →</a>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- Services teaser -->
  <section class="border-t border-line bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="font-utility text-xs uppercase tracking-widest text-mist">Services</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">Four ways in</h2>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <!-- The flagship door gets the weight -->
        <a
          href="/services/"
          class="group flex flex-col justify-between bg-ink p-8 text-porcelain transition-transform duration-200 hover:-translate-y-1 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
        >
          <div>
            <p class="font-utility text-xs uppercase tracking-widest text-flare">
              Most rescues start here
            </p>
            <h3 class="mt-4 font-display text-3xl font-bold tracking-tight">Website Rescue</h3>
            <p class="mt-4 max-w-md text-porcelain/80">
              Stuck on Wix or Squarespace, paying every month for a slow site? I rebuild it fast,
              findable, and fee-free — and the subscription goes away for good.
            </p>
            <dl class="mt-8 max-w-md space-y-3 font-utility text-sm">
              <div class="flex justify-between gap-4 border-b border-dotted border-porcelain/25 pb-3">
                <dt class="text-porcelain/70">Platform subscription</dt>
                <dd class="font-bold text-flare">cancelled</dd>
              </div>
              <div class="flex justify-between gap-4 border-b border-dotted border-porcelain/25 pb-3">
                <dt class="text-porcelain/70">Your content &amp; domain</dt>
                <dd class="font-bold">kept</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-porcelain/70">Google &amp; AI search</dt>
                <dd class="font-bold">findable</dd>
              </div>
            </dl>
          </div>
          <p class="mt-8 flex flex-wrap items-center justify-between gap-x-6 gap-y-2 font-utility text-sm">
            <span class="whitespace-nowrap uppercase tracking-widest text-porcelain/60">
              Fixed price
            </span>
            <span class="whitespace-nowrap font-bold group-hover:text-flare">
              How a rescue works →
            </span>
          </p>
        </a>

        <div class="flex flex-col gap-6">
          {
            doors.map(({ name, blurb, meta }) => (
              <a
                href="/services/"
                class="group flex flex-1 flex-col justify-between border border-line bg-porcelain p-6 transition-colors hover:border-ink"
              >
                <div>
                  <h3 class="font-display text-xl font-semibold">{name}</h3>
                  <p class="mt-2 text-mist">{blurb}</p>
                </div>
                <p class="mt-4 font-utility text-xs uppercase tracking-widest text-mist group-hover:text-ink">
                  {meta}
                </p>
              </a>
            ))
          }
        </div>
      </div>

      <a href="/services/" class="mt-10 inline-block font-semibold text-steel underline">
        Details, engagement, and availability →
      </a>
    </div>
  </section>

  <!-- Proof strip -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <p class="font-utility text-xs uppercase tracking-widest text-mist">Case study</p>
    <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">Recent rescue</h2>
    <p class="mt-4 max-w-2xl text-mist">
      A children's book author was paying monthly for a slow Wix site. I rebuilt it: loads in under
      a second, found on Google, and the platform fee went to zero.
    </p>

    <dl class="mt-8 grid max-w-3xl gap-px border border-line bg-line sm:grid-cols-3">
      <div class="bg-white p-5">
        <dt class="font-utility text-xs uppercase tracking-widest text-mist">Monthly fee</dt>
        <dd class="mt-2 font-utility text-2xl font-bold text-flare">$0</dd>
      </div>
      <div class="bg-white p-5">
        <dt class="font-utility text-xs uppercase tracking-widest text-mist">Loads in</dt>
        <dd class="mt-2 font-utility text-2xl font-bold text-steel">&lt; 1 second</dd>
      </div>
      <div class="bg-white p-5">
        <dt class="font-utility text-xs uppercase tracking-widest text-mist">On Google</dt>
        <dd class="mt-2 font-utility text-2xl font-bold text-steel">Found</dd>
      </div>
    </dl>

    <a href="/case-studies/" class="mt-8 inline-block font-semibold text-steel underline">
      Read the case study →
    </a>
  </section>
</Base>
