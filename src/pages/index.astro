---
import Base from '../layouts/Base.astro';
import AvailabilityBadge from '../components/AvailabilityBadge.astro';

const doors = [
  {
    name: 'New Website Build',
    blurb: 'Starting from zero, built right the first time.',
    meta: 'Fixed price',
    icon: 'build',
  },
  {
    name: 'Site Checkup',
    blurb: 'A fixed-price audit of speed and Google visibility, in plain English.',
    meta: 'Fixed price',
    icon: 'checkup',
  },
  {
    name: 'Care Plan',
    blurb: 'Monthly updates and monitoring, so your site never rots again.',
    meta: 'Monthly retainer',
    icon: 'care',
  },
];
---

<Base
  title="Gian Trotta — Fast websites for Northeast Ohio small businesses"
  description="Your website should bring in customers, not another monthly bill. Website rescues, rebuilds, and checkups for Northeast Ohio small businesses."
>
  <!-- Hero: headline vs. the receipt that proves it -->
  <section class="mx-auto max-w-6xl px-6 pb-20 pt-16 lg:pt-20">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p
          class="flex flex-wrap items-center gap-x-2 gap-y-1 font-utility text-sm uppercase tracking-widest text-flare-deep"
        >
          <span class="w-full sm:w-auto">Cleveland, Ohio</span>
          <span aria-hidden="true" class="hidden sm:inline">·</span>
          <AvailabilityBadge />
        </p>
        <h1
          class="mt-4 font-display text-5xl font-bold leading-tight tracking-tight sm:text-6xl xl:text-7xl"
        >
          Your website should bring in customers, <span class="hero-underline">not another monthly bill.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-mist">
          I get small-business sites off monthly builders and onto something that loads fast, shows
          up in search, and doesn't charge rent.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="bg-flare-deep px-6 py-3 font-semibold text-porcelain transition-transform duration-150 hover:-translate-y-0.5 hover:bg-flare hover:shadow-lg motion-reduce:hover:translate-y-0"
          >
            Book a free 15-minute call
          </a>
          <a
            href="/services/"
            class="border border-ink px-6 py-3 font-semibold transition-transform duration-150 hover:-translate-y-0.5 hover:bg-ink hover:text-porcelain hover:shadow-lg motion-reduce:hover:translate-y-0"
          >
            See services
          </a>
        </div>
      </div>

      <!-- Signature: the checkup receipt — this site's own diagnostic slip -->
      <aside
        class="receipt-wrap transition-transform duration-300 lg:col-span-5 lg:-rotate-2 lg:hover:rotate-0 motion-reduce:transition-none"
        aria-label="This site's own checkup results"
      >
        <div class="receipt-paper px-7 py-9 font-utility">
          <p class="text-xs uppercase tracking-widest text-mist">
            Site checkup · giantrotta.dev
          </p>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between gap-4 border-b border-dotted border-line pb-3">
              <dt>Google speed score</dt>
              <dd class="font-bold text-steel">100 / 100</dd>
            </div>
            <div class="flex justify-between gap-4 border-b border-dotted border-line pb-3">
              <dt>Loads in</dt>
              <dd class="font-bold text-steel">under 1 second</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt>Monthly platform fee</dt>
              <dd class="font-bold text-flare-deep">$0</dd>
            </div>
          </dl>
          <p class="mt-6 border-t border-dashed border-line pt-4 text-xs leading-relaxed text-mist">
            This site is built the way I build yours. The previous version took 72 seconds to load
            on a phone.
            <a href="/blog/why-my-portfolio-took-72-seconds-to-load/" class="underline hover:text-ink">That story →</a>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- Services teaser -->
  <section class="border-t border-line bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="font-utility text-xs uppercase tracking-widest text-mist">Services</p>
      <h2 class="section-heading mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
        Four ways in
      </h2>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <!-- The flagship door gets the weight -->
        <a
          href="/services/"
          class="group flex flex-col justify-between bg-ink p-8 text-porcelain transition-transform duration-200 hover:-translate-y-1 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
        >
          <div>
            <svg
              class="h-9 w-9 text-flare"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M2.5 12h4l1.8-4.5L11 16l2.2-8 1.5 4.5h6.8" />
            </svg>
            <p class="mt-4 font-utility text-xs uppercase tracking-widest text-flare-bright">
              Most rescues start here
            </p>
            <h3 class="mt-4 font-display text-3xl font-bold tracking-tight">Website Rescue</h3>
            <p class="mt-4 max-w-md text-porcelain/80">
              Stuck on a slow Wix or Squarespace site? I rebuild it fast and fee-free,
              subscription cancelled for good.
            </p>
            <dl class="mt-8 max-w-md space-y-3 font-utility text-sm">
              <div class="flex justify-between gap-4 border-b border-dotted border-porcelain/25 pb-3">
                <dt class="text-porcelain/70">Platform subscription</dt>
                <dd class="font-bold text-flare-bright">cancelled</dd>
              </div>
              <div class="flex justify-between gap-4 border-b border-dotted border-porcelain/25 pb-3">
                <dt class="text-porcelain/70">Your content &amp; domain</dt>
                <dd class="font-bold">kept</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-porcelain/70">Google &amp; AI search</dt>
                <dd class="font-bold">findable</dd>
              </div>
            </dl>
          </div>
          <p class="mt-8 flex flex-wrap items-center justify-between gap-x-6 gap-y-2 font-utility text-sm">
            <span class="whitespace-nowrap uppercase tracking-widest text-porcelain/60">
              Fixed price
            </span>
            <span class="whitespace-nowrap font-bold group-hover:text-flare-bright">
              How a rescue works →
            </span>
          </p>
        </a>

        <div class="flex flex-col gap-6">
          {
            doors.map(({ name, blurb, meta, icon }) => (
              <a
                href="/services/"
                class="group flex flex-1 flex-col justify-between border border-line bg-porcelain p-6 transition-all duration-200 hover:-translate-y-1 hover:border-ink hover:shadow-lg motion-reduce:hover:translate-y-0"
              >
                <div>
                  <svg
                    class="h-7 w-7 text-flare"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {icon === 'build' && (
                      <>
                        <rect x="4.5" y="3" width="15" height="18" rx="1.5" />
                        <path d="M9 12h6M12 9v6" />
                      </>
                    )}
                    {icon === 'checkup' && (
                      <>
                        <circle cx="10.5" cy="10.5" r="6.5" />
                        <path d="M15.3 15.3 20.5 20.5" />
                        <path d="M7.3 10.5h1.3l1-2.2 1.3 4.4 1-2.2h1.3" />
                      </>
                    )}
                    {icon === 'care' && (
                      <path d="M12 19.5s-7-4.2-9-8.1C1.4 8 2.6 4.8 5.8 4.8c1.9 0 3.2 1.1 3.9 2.1.7-1 2-2.1 3.9-2.1 3.2 0 4.4 3.2 2.8 6.6-2 3.9-9 8.1-9 8.1z" />
                    )}
                  </svg>
                  <h3 class="mt-3 font-display text-xl font-semibold">{name}</h3>
                  <p class="mt-2 text-mist">{blurb}</p>
                </div>
                <p class="mt-4 font-utility text-xs uppercase tracking-widest text-mist group-hover:text-ink">
                  {meta}
                </p>
              </a>
            ))
          }
        </div>
      </div>

      <a href="/services/" class="group mt-10 inline-block font-semibold text-steel underline">
        Details <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>

  <!-- Proof strip -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <p class="font-utility text-xs uppercase tracking-widest text-mist">Case study</p>
    <h2 class="section-heading mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
      Recent rescue
    </h2>
    <p class="mt-4 max-w-2xl text-mist">
      A children's book author was paying monthly for a slow Wix site. I rebuilt it: loads in under
      a second, found on Google, and the platform fee went to zero.
    </p>

    <dl class="mt-8 grid max-w-3xl gap-px border border-line bg-line sm:grid-cols-3">
      <div class="bg-white p-5">
        <dt class="font-utility text-xs uppercase tracking-widest text-mist">Monthly fee</dt>
        <dd class="mt-2 font-utility text-2xl font-bold text-flare">$0</dd>
      </div>
      <div class="bg-white p-5">
        <dt class="font-utility text-xs uppercase tracking-widest text-mist">Loads in</dt>
        <dd class="mt-2 font-utility text-2xl font-bold text-steel">&lt; 1 second</dd>
      </div>
      <div class="bg-white p-5">
        <dt class="font-utility text-xs uppercase tracking-widest text-mist">On Google</dt>
        <dd class="mt-2 font-utility text-2xl font-bold text-steel">Found</dd>
      </div>
    </dl>

    <a href="/case-studies/rusty/" class="group mt-8 inline-block font-semibold text-steel underline">
      Read the case study
      <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
    </a>
  </section>

  <!-- Where I've been -->
  <section class="border-t border-line bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="font-utility text-xs uppercase tracking-widest text-mist">A little more context</p>
      <h2 class="section-heading mt-3 font-display text-2xl font-bold tracking-tight sm:text-3xl">
        Where I've been
      </h2>

      <div class="mt-10 grid gap-10 sm:grid-cols-3">
        <div>
          <p class="font-utility text-xs uppercase tracking-widest text-mist">
            Websites I've built
          </p>
          <ul class="mt-3 space-y-2">
            <li>
              <a
                href="/case-studies/rusty/"
                class="inline-block font-display text-lg font-semibold tracking-tight transition-transform duration-150 hover:translate-x-1 hover:text-flare motion-reduce:hover:translate-x-0"
              >
                Rusty the Raccoon
              </a>
            </li>
            <li>
              <a
                href="/case-studies/fresh-beginnings/"
                class="inline-block font-display text-lg font-semibold tracking-tight transition-transform duration-150 hover:translate-x-1 hover:text-flare motion-reduce:hover:translate-x-0"
              >
                Fresh Beginnings Publishing
              </a>
            </li>
          </ul>
        </div>

        <div>
          <p class="font-utility text-xs uppercase tracking-widest text-mist">
            Freelance work
          </p>
          <ul class="mt-3 space-y-2">
            <li>
              <a
                href="https://edhlab.gg"
                class="inline-block font-display text-lg font-semibold tracking-tight transition-transform duration-150 hover:translate-x-1 hover:text-flare motion-reduce:hover:translate-x-0"
                rel="noopener noreferrer"
                target="_blank"
              >
                EDHLAB
              </a>
            </li>
            <li>
              <a
                href="https://clockwork9.com"
                class="inline-block font-display text-lg font-semibold tracking-tight transition-transform duration-150 hover:translate-x-1 hover:text-flare motion-reduce:hover:translate-x-0"
                rel="noopener noreferrer"
                target="_blank"
              >
                Clockwork9
              </a>
            </li>
          </ul>
        </div>

        <div>
          <p class="font-utility text-xs uppercase tracking-widest text-mist">My 9-to-5</p>
          <ul class="mt-3 space-y-2">
            <li>
              <a
                href="https://rvshare.com"
                class="inline-block font-display text-lg font-semibold tracking-tight transition-transform duration-150 hover:translate-x-1 hover:text-flare motion-reduce:hover:translate-x-0"
                rel="noopener noreferrer"
                target="_blank"
              >
                RVshare
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Base>
