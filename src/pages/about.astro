---
import Base from '../layouts/Base.astro';
---

<Base
  title="About — Gian Trotta"
  description="Senior software engineer in Cleveland, Ohio. I've spent years making one very large website fast — now I do it for businesses whose owners I can shake hands with."
>
  <section class="mx-auto max-w-5xl px-6 pb-12 pt-16">
    <p class="font-utility text-xs uppercase tracking-widest text-flare-deep">About</p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
      Gian Trotta
    </h1>

    <div class="mt-12 grid items-start gap-10 lg:grid-cols-12">
      <figure class="lg:col-span-5">
        <picture>
          <source srcset="/about/self-portrait.webp" type="image/webp" />
          <img
            src="/about/self-portrait.jpg"
            alt="Gian Trotta with his daughter"
            width="900"
            height="1200"
            class="w-full max-w-md object-cover object-[center_20%] lg:max-w-none"
            loading="eager"
            decoding="async"
          />
        </picture>
        <figcaption class="mt-3 font-utility text-xs uppercase tracking-widest text-mist">
          Cleveland, Ohio · with my daughter
        </figcaption>
      </figure>

      <div class="space-y-6 text-lg leading-relaxed lg:col-span-7">
        <p>
          I've been at
          <a
            href="https://rvshare.com"
            class="font-semibold text-steel underline hover:text-ink"
            target="_blank"
            rel="noopener noreferrer"
          >RVshare</a>
          since 2019, now as a senior engineer on an RV rental marketplace that serves millions of
          visitors. Keeping that very large site fast, visible in search, and reliable is my day job.
        </p>
        <p>
          Now I'm bringing that work to local businesses and owners.
          I'm early here, so you get senior-level work,and a developer who wants your
          project to be one I'm proud to show.
        </p>
        <p>
          I live in Cleveland with my wife and daughter. In my free time I love watching Cleveland sports, playing poker, and collecting Magic: the Gathering cards.
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-white" aria-label="Northeast Ohio">
    <div class="mx-auto max-w-5xl px-6 py-12">
      <figure>
        <picture>
          <source srcset="/about/cleveland.webp" type="image/webp" />
          <img
            src="/about/cleveland.jpg"
            alt="Cleveland script sign overlooking the downtown skyline at dusk"
            width="1600"
            height="1066"
            class="w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </picture>
        <figcaption class="mt-4 font-utility text-xs uppercase tracking-widest text-mist">
          Cleveland · Northeast Ohio
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-16">
    <a
      href="/contact/"
      class="inline-block bg-flare-deep px-6 py-3 font-semibold text-porcelain hover:bg-flare"
    >
      Book a free 15-minute call
    </a>
  </section>
</Base>
