---
interface Stat {
  label: string;
  value: string;
  note?: string;
}

interface Props {
  stats: Stat[];
  cols?: number;
  valueClass?: string;
  noteClass?: string;
}

const {
  stats,
  cols = 4,
  valueClass = 'text-xl sm:text-2xl',
  noteClass = 'mt-2 text-sm',
} = Astro.props;

const colsClass: Record<number, string> = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};
---

<dl class={`grid gap-px border border-line bg-line ${colsClass[cols] ?? colsClass[4]}`}>
  {
    stats.map(({ label, value, note }) => (
      <div class="bg-white p-5">
        <dt class="eyebrow">{label}</dt>
        <dd class={`mt-2 font-utility font-bold text-steel ${valueClass}`}>{value}</dd>
        {note && <dd class={`text-mist ${noteClass}`}>{note}</dd>}
      </div>
    ))
  }
</dl>
