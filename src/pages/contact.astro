---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact — Gian Trotta"
  description="Tell me about your project or book a free 15-minute call. Website rescues and builds for Northeast Ohio small businesses."
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-display text-4xl font-bold tracking-tight sm:text-5xl">
      Have a website problem?
    </h1>
    <p class="mt-4 text-lg text-mist">
      Two ways in — write to me, or grab a time directly. Either way, you'll get a straight answer
      about whether I can help.
    </p>

    <!-- Netlify Forms: must stay static HTML so the build bot registers it -->
    <form
      name="project"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="mt-10 space-y-6"
    >
      <input type="hidden" name="form-name" value="project" />
      <p class="hidden">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div>
        <label for="name" class="block font-semibold">Your name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="mt-2 w-full border border-line bg-white px-4 py-3"
        />
      </div>

      <div>
        <label for="email" class="block font-semibold">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="mt-2 w-full border border-line bg-white px-4 py-3"
        />
      </div>

      <div>
        <label for="message" class="block font-semibold">What's going on with your site?</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="mt-2 w-full border border-line bg-white px-4 py-3"
          placeholder="It's slow, it costs me every month, nobody can find it…"></textarea>
      </div>

      <button
        type="submit"
        class="bg-flare-deep px-6 py-3 font-semibold text-porcelain hover:bg-flare"
      >
        Send it
      </button>
    </form>

    <div class="mt-12 border-2 border-dashed border-ink bg-white p-8">
      <h2 class="font-display text-2xl font-bold">Rather just talk?</h2>
      <p class="mt-2 text-mist">
        Book a free 15-minute call — no prep needed.
      </p>
      <a
        id="book-call"
        href="https://cal.com/gian-trotta-wysuez/15min"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-block bg-flare-deep px-6 py-3 font-semibold text-porcelain hover:bg-flare"
      >
        Book a time →
      </a>
    </div>
  </section>

  <!--
    Cal.com booking, loaded lazily: this defines window.Cal but fetches nothing.
    The real embed script only loads on click, so the button costs ~0 bytes until used.
  -->
  <script is:inline>
    (function (C, A, L) {
      let p = function (a, ar) {
        a.q.push(ar);
      };
      let d = C.document;
      C.Cal =
        C.Cal ||
        function () {
          let cal = C.Cal;
          let ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement('script')).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () {
              p(api, arguments);
            };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === 'string') {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ['initNamespace', namespace]);
            } else p(cal, ar);
            return;
          }
          p(cal, ar);
        };
    })(window, 'https://app.cal.com/embed/embed.js', 'init');
  </script>
  <script is:inline>
    document.getElementById('book-call').addEventListener(
      'click',
      function (e) {
        e.preventDefault();
        Cal('init', { origin: 'https://cal.com' });
        Cal('ui', {
          styles: { branding: { brandColor: '#e8531f' } },
          hideEventTypeDetails: false,
          layout: 'month_view',
        });
        Cal('modal', { calLink: 'gian-trotta-wysuez/15min' });
      },
      { once: true }
    );
  </script>
</Base>
